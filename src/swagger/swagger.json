{
  "openapi": "3.0.0",
  "info": {
    "title": "Payment Processing System API",
    "version": "1.0.0",
    "description": "API documentation for payment processing system"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api/v1"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check APIs"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check endpoint",
        "description": "Returns service health status",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Service is healthy",
                  "data": {
                    "uptime": 12.34,
                    "timestamp": "2026-01-01T10:00:00.000Z"
                  },
                  "error": null
                }
              }
            }
          }
        }
      }
    }
  }
}
